{
  "name": "torch-overlay",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "smoke:web": "node scripts/smoke-web.mjs",
    "verify": "npm run check && npm run build && cargo fmt --check --manifest-path src-tauri/Cargo.toml && cargo test --manifest-path src-tauri/Cargo.toml",
    "debug:tauri": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev_tauri.ps1",
    "build:release:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build_release_local.ps1",
    "update:test:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build_update_test.ps1",
    "update:test:server": "node scripts/update-test-server.mjs",
    "update:test:install-old": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install_update_test_old.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^25.6.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0"
  }
}
